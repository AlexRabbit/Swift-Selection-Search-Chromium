{
	"manifest_version": 3,
	"name": "Swift Selection Search",
	"version": "3.49.0",
	"minimum_chrome_version": "102",

	"description": "Swiftly access your search engines in a popup panel when you select text in a webpage. Context search menu also included!",
	"homepage_url": "https://github.com/AlexRabbit/Swift-Selection-Search-Chromium",

	"icons": {
		"48": "icons/icon48.png",
		"96": "icons/icon96.png"
	},

	"background": {
		"service_worker": "service-worker-bootstrap.js"
	},

	"options_ui": {
		"page": "settings/settings.html",
		"open_in_tab": true
	},

	"permissions": [
		"storage",
		"contextMenus",
		"search",
		"scripting",
		"webNavigation",
		"clipboardWrite"
	],
	"host_permissions": ["<all_urls>"],
	"optional_permissions": ["downloads", "tabs"],

	"commands": {
		"open-popup": {
			"suggested_key": { "default": "Ctrl+Shift+Space" },
			"description": "Open the popup (if text is selected)"
		},
		"toggle-auto-popup": {
			"suggested_key": { "default": "Ctrl+Shift+U" },
			"description": "Switch popup opening behaviour between \"Auto\" and \"Keyboard-only\""
		}
	},

	"web_accessible_resources": [
		{
			"resources": ["res/*"],
			"matches": ["<all_urls>"]
		}
	]
}
