{
  "name": "swift-selection-search",
  "version": "3.49.0",
  "description": "Swift Selection Search (SSS) — Manifest V3 extension for Chromium browsers (Brave, Chrome, Edge). Select text, get a fast engine popup and context menu.",
  "main": "src/swift-selection-search.js",
  "homepage": "https://github.com/AlexRabbit/Swift-Selection-Search-Chromium",
  "scripts": {
    "build": "tsc -p tsconfig.json && npm run build:tests",
    "build:tests": "esbuild tests/browser-entry.ts --bundle --outfile=tests/tests-browser-bundle.js --format=iife --platform=browser",
    "watch": "tsc -p tsconfig.json --watch",
    "test": "tsx tests/browser-entry.ts",
    "check": "npm run build && npm test"
  },
  "author": "Daniel Lobo",
  "license": "MIT",
  "dependencies": {
    "@types/firefox-webext-browser": "^82.0.0",
    "typescript": "^5.7.3",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "tsx": "^4.19.3"
  }
}
