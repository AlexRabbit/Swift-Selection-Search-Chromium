{
	"compilerOptions": {
		"target": "ES2020",
		"module": "none",
		"lib": ["ES2020", "DOM", "DOM.Iterable"],
		"inlineSourceMap": true,
		"typeRoots": ["node_modules/@types"],
		"newLine": "LF",
		"removeComments": true,
		"skipLibCheck": true
	},
	"include": ["src/**/*.ts"],
	"exclude": ["node_modules", "tests"]
}
